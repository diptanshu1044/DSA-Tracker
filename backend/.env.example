# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/dsa-tracker

# JWT — access tokens are short-lived; refresh tokens last longer
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret-32chars
JWT_REFRESH_EXPIRES_IN=7d

# Frontend
CLIENT_URL=http://localhost:3000

# Google OAuth (optional in development; set all three in production)
# Callback must match Google Cloud Console redirect URI exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Cookies — set COOKIE_SECURE=true in production (enables SameSite=None for cross-origin)
COOKIE_SECURE=false

# Optional SMTP (required for password-reset email delivery in production)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=DSA Tracker <noreply@dsa-tracker.local>
